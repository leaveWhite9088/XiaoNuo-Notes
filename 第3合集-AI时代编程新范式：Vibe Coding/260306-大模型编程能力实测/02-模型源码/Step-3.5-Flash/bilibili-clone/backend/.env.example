# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Session Secret (generate a random string)
SESSION_SECRET=your-session-secret-key-here

# JWT Secret
JWT_SECRET=your-jwt-secret-key-here

# Bilibili API Configuration
# Note: bilibili-api library handles authentication internally
# You may need to provide your own Bilibili account credentials for certain features
BILIBILI_COOKIE=  # Optional: your Bilibili cookie for authenticated requests